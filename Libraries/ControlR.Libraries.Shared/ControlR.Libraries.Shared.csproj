<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<IsPackable>true</IsPackable>
		<Title>ControlR Libraries Shared</Title>
		<Description>
		  Shared utilities for ControlR, an open-source remote control and remote access solution.
		</Description>
		<PackageIcon>appicon.png</PackageIcon>
		<IsNuGetPackage>true</IsNuGetPackage>
	</PropertyGroup>
	<ItemGroup>
		<None Include="..\..\.assets\appicon.png">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="MessagePack" />
		<PackageReference Include="Microsoft.Extensions.Caching.Memory" />
		<PackageReference Include="Microsoft.Extensions.Logging" />
		<PackageReference Include="Microsoft.IO.RecyclableMemoryStream" />
		<PackageReference Include="Microsoft.Extensions.Http" />
		<PackageReference Update="Bitbound.Analyzers.MemberOrder">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>
	<ItemGroup>
		<EditorConfigFiles Remove="C:\Repos\ControlR\ControlR.Shared\.editorconfig" />
	</ItemGroup>
	<ItemGroup>
	  <ProjectReference Include="..\ControlR.Libraries.Api.Contracts\ControlR.Libraries.Api.Contracts.csproj" />
	</ItemGroup>
</Project>
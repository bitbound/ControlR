<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <Title>ControlR Libraries WebSocket Relay Client</Title>
    <Description>
      WebSocket relay client utilities for ControlR, an open-source remote control and remote access solution.
    </Description>
    <PackageIcon>appicon.png</PackageIcon>
    <IsNuGetPackage>true</IsNuGetPackage>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\..\.assets\appicon.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Bitbound.SimpleMessenger" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ControlR.Libraries.Shared\ControlR.Libraries.Shared.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Update="Bitbound.Analyzers.MemberOrder">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>

  "components": {
    "schemas": {
      "Architecture": {
        "type": "integer"
      },
      "CreateDeviceRequestDto": {
        "required": [
          "device",
          "installerKeyId",
          "installerKeySecret"
        ],
        "type": "object",
        "properties": {
          "device": {
            "$ref": "#/components/schemas/DeviceUpdateRequestDto"
          },
          "installerKeyId": {
            "type": "string",
            "format": "uuid"
          },
          "installerKeySecret": {
            "type": "string"
          },
          "tagIds": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "publicKey": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateInstallerKeyRequestDto": {
        "required": [
          "tenantId",
          "creatorId",
          "creatorKind",
          "keyType"
        ],
        "type": "object",
        "properties": {
          "tenantId": {
            "type": "string",
            "format": "uuid"
          },
          "creatorId": {
            "type": "string",
            "format": "uuid"
          },
          "creatorKind": {
            "$ref": "#/components/schemas/CreatorKind"
          },
          "keyType": {
            "$ref": "#/components/schemas/InstallerKeyType"
          },
          "friendlyName": {
            "type": [
              "null",
              "string"
            ]
          },
          "allowedUses": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer"
            ],
            "format": "int32"
          },
          "expiration": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          }
        }
      },
      "CreateInstallerKeyResponseDto": {
        "required": [
          "id",
          "creatorId",
          "keyType",
          "keySecret",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "creatorId": {
            "type": "string",
            "format": "uuid"
          },
          "keyType": {
            "$ref": "#/components/schemas/InstallerKeyType"
          },
          "keySecret": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "allowedUses": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer"
            ],
            "format": "int32"
          },
          "expiration": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "friendlyName": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateTenantRequestDto": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          }
        }
      },
      "CreateTenantResponseDto": {
        "required": [
          "tenantId",
          "tenantName"
        ],
        "type": "object",
        "properties": {
          "tenantId": {
            "type": "string",
            "format": "uuid"
          },
          "tenantName": {
            "type": "string"
          }
        }
      },
      "CreatorKind": {
        "type": "integer"
      },
      "DeleteDevicesRequestDto": {
        "required": [
          "deviceIds"
        ],
        "type": "object",
        "properties": {
          "deviceIds": {
            "maxItems": 1000,
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "DeleteManyDevicesResponseDto": {
        "required": [
          "successIds",
          "failureIds"
        ],
        "type": "object",
        "properties": {
          "successIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "failureIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      },
      "DeviceColumnFilter": {
        "type": "object",
        "properties": {
          "operator": {
            "type": [
              "null",
              "string"
            ]
          },
          "propertyName": {
            "type": [
              "null",
              "string"
            ]
          },
          "value": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "DeviceColumnSort": {
        "type": "object",
        "properties": {
          "descending": {
            "type": "boolean"
          },
          "propertyName": {
            "type": [
              "null",
              "string"
            ]
          },
          "sortOrder": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "DeviceResponseDto": {
        "required": [
          "name",
          "agentVersion",
          "cpuUtilization",
          "id",
          "is64Bit",
          "isOnline",
          "lastSeen",
          "osArchitecture",
          "platform",
          "processorCount",
          "connectionId",
          "osDescription",
          "tenantId",
          "totalMemory",
          "totalStorage",
          "usedMemory",
          "usedStorage",
          "currentUsers",
          "macAddresses",
          "publicIpV4",
          "publicIpV6",
          "localIpV4",
          "localIpV6",
          "drives",
          "isOutdated"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "agentVersion": {
            "type": "string"
          },
          "cpuUtilization": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "id": {
            "type": "string",
            "format": "uuid"

@page "/password-change-required"
@attribute [ExcludeFromInteractiveRouting]
@layout AccountLayout
@attribute [Authorize]

@inject UserManager<AppUser> UserManager
@inject SignInManager<AppUser> SignInManager
@inject IPasswordManager PasswordManager
@inject ILogger<PasswordChangeRequired> Logger

<PageTitle>Change password</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true" Color="Color.Primary">Change password</MudText>

<MudText Typo="Typo.body2" Class="mb-2" Color="Color.Error">
  You must change your temporary password before continuing.
</MudText>

@if (!string.IsNullOrEmpty(_message))
{
  var severity = _message.StartsWith("Error") ? Severity.Error : Severity.Success;
  <MudAlert Severity="@severity" Variant="Variant.Outlined" Class="mb-4">
    @_message
  </MudAlert>
}

<EditForm Model="Input" FormName="password-change-required" OnValidSubmit="OnValidSubmitAsync" method="post">
  <DataAnnotationsValidator />

  <div style="max-width: 500px;" class="d-flex flex-column gap-3">
    <MudStaticTextField For="@(() => Input.TemporaryPassword)"
                        @bind-Value="Input.TemporaryPassword"
                        InputType="InputType.Password"
                        Label="Temporary password"
                        Placeholder="temporary password"
                        HelperText="Please enter your temporary password."
                        UserAttributes="@(new Dictionary<string, object?> { { "autocomplete", "current-password" }, { "aria-required", "true" } })" />

    <MudStaticTextField For="@(() => Input.NewPassword)"
                        @bind-Value="Input.NewPassword"
                        InputType="InputType.Password"
                        Label="New password"
                        Placeholder="new password"
                        HelperText="Please enter your new password."
                        UserAttributes="@(new Dictionary<string, object?> { { "autocomplete", "new-password" }, { "aria-required", "true" } })" />

    <MudStaticTextField For="@(() => Input.ConfirmPassword)"
                        @bind-Value="Input.ConfirmPassword"
                        InputType="InputType.Password"
                        Label="Confirm new password"
                        Placeholder="confirm new password"
                        HelperText="Please confirm your new password."
                        UserAttributes="@(new Dictionary<string, object?> { { "autocomplete", "new-password" }, { "aria-required", "true" } })" />

    <MudStaticButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" FormAction="FormAction.Submit">
      Change password
    </MudStaticButton>
  </div>
</EditForm>

@code {
  [CascadingParameter]
  private HttpContext HttpContext { get; set; } = default!;

  [SupplyParameterFromForm]
  private InputModel Input { get; set; } = default!;

  private string? _message;

  protected override void OnInitialized()
  {
    Input ??= new();
  }

  private async Task OnValidSubmitAsync()
  {
    _message = null;

    var user = await UserManager.GetUserAsync(HttpContext.User);
    if (user is null)
    {
      _message = "Error: User not found.";
      return;
    }

    var request = new ChangePasswordRequestDto(Input.TemporaryPassword, Input.NewPassword);
    var result = await PasswordManager.ChangePassword(user, request);

    if (!result.IsSuccess)
    {
      _message = $"Error: {result.Reason}";
      return;
    }

    await SignInManager.RefreshSignInAsync(user);
    Logger.LogInformation("User changed their temporary password successfully.");

    HttpContext.Response.Redirect("/");
  }

  private sealed class InputModel
  {
    [Required]
    [DataType(DataType.Password)]
    [Display(Name = "Temporary password")]
    public string TemporaryPassword { get; set; } = "";

    [Required]
    [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
    [DataType(DataType.Password)]
    [Display(Name = "New password")]
    public string NewPassword { get; set; } = "";

    [DataType(DataType.Password)]
    [Display(Name = "Confirm new password")]
    [Compare("NewPassword", ErrorMessage = "The new password and confirmation password do not match.")]
    public string ConfirmPassword { get; set; } = "";
  }
}

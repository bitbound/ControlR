@page "/Account/ForgotPassword"

@inject UserManager<AppUser> UserManager
@inject IEmailSender<AppUser> EmailSender
@inject IOptionsMonitor<AppOptions> AppOptions
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject IPasswordManager PasswordManager

<PageTitle>Forgot your password?</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Forgot your password?</MudText>

@if (AppOptions.CurrentValue.DisableEmailSending)
{
  <MudAlert Severity="Severity.Warning">
    System emails are disabled.  Please contact your administrator.
  </MudAlert>
}
else
{
  <MudText Typo="Typo.body1" GutterBottom="true">Enter your email.</MudText>

  <EditForm Model="Input" FormName="forgot-password" OnValidSubmit="OnValidSubmitAsync" method="post">
    <DataAnnotationsValidator />

    <MudGrid>
      <MudItem xs="12" sm="6">
        <MudStaticTextField For="@(() => Input.Email)" @bind-Value="Input.Email" Label="Email"
                            Placeholder="name@example.com"
                            UserAttributes="@(new() { { "autocomplete", "username" }, { "aria-required", "true" } })"
                            Class="mb-3" />

        <MudStaticButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                         FormAction="FormAction.Submit">Reset password</MudStaticButton>
      </MudItem>
    </MudGrid>
  </EditForm>
}

@code {
  [SupplyParameterFromForm]
  private InputModel Input { get; set; } = default!;

  protected override Task OnInitializedAsync()
  {
    Input ??= new InputModel();
    return Task.CompletedTask;
  }

  private async Task OnValidSubmitAsync()
  {
    if (AppOptions.CurrentValue.DisableEmailSending)
    {
      return;
    }

    var callbackUrl = NavigationManager.ToAbsoluteUri("Account/ResetPassword").AbsoluteUri;
    var result = await PasswordManager.ForgotPassword(new ForgotPasswordRequestDto(Input.Email), callbackUrl);
    if (!result.IsSuccess)
    {
      return;
    }

    RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
  }

  private sealed class InputModel
  {
    [Required]
    [EmailAddress]
    public string Email { get; set; } = "";
  }
}
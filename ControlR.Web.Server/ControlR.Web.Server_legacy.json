{
  "openapi": "3.1.1",
  "info": {
    "title": "ControlR | Legacy API",
    "description": "ControlR's legacy API.  This API is deprecated and will be removed in a future release.",
    "version": "Legacy"
  },
  "paths": {
    "/api/agent-update/get-bundle-metadata/{runtime}": {
      "get": {
        "tags": [
          "AgentUpdate"
        ],
        "parameters": [
          {
            "name": "runtime",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/RuntimeId"
            }
          },
          {
            "name": "api-version",
            "in": "query",
            "description": "The requested API version",
            "schema": {
              "enum": [
                "0.0"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BundleMetadataDto"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/devices": {
      "post": {
        "tags": [
          "Devices"
        ],
        "parameters": [
          {
            "name": "api-version",
            "in": "query",
            "description": "The requested API version",
            "schema": {
              "enum": [
                "0.0"
              ],
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDeviceRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDeviceRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDeviceRequestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceResponseDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceResponseDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceResponseDto"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Architecture": {
        "type": "integer"
      },
      "BundleMetadataDto": {
        "required": [
          "bundleDownloadUrl",
          "bundleSha256",
          "installerDownloadUrl",
          "installerSha256",
          "runtime",
          "version"
        ],
        "type": "object",
        "properties": {
          "bundleDownloadUrl": {
            "type": "string"
          },
          "bundleSha256": {
            "type": "string"
          },
          "installerDownloadUrl": {
            "type": "string"
          },
          "installerSha256": {
            "type": "string"
          },
          "runtime": {
            "$ref": "#/components/schemas/RuntimeId"
          },
          "version": {
            "pattern": "^\\d+(\\.\\d+){1,3}$",
            "type": "string"
          }
        }
      },
      "CreateDeviceRequestDto": {
        "required": [
          "device",
          "installerKeyId",
          "installerKeySecret"
        ],
        "type": "object",
        "properties": {
          "device": {
            "$ref": "#/components/schemas/DeviceUpdateRequestDto"
          },
          "installerKeyId": {
            "type": "string",
            "format": "uuid"
          },
          "installerKeySecret": {
            "type": "string"
          },
          "tagIds": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "publicKey": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "DeviceResponseDto": {
        "required": [
          "name",
          "agentVersion",
          "cpuUtilization",
          "id",
          "is64Bit",
          "isOnline",
          "lastSeen",
          "osArchitecture",
          "platform",
          "processorCount",
          "connectionId",
          "osDescription",
          "tenantId",
          "totalMemory",
          "totalStorage",
          "usedMemory",
          "usedStorage",
          "currentUsers",
          "macAddresses",
          "publicIpV4",
          "publicIpV6",
          "localIpV4",
          "localIpV6",
          "drives",
          "isOutdated"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "agentVersion": {
            "type": "string"
          },
          "cpuUtilization": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "is64Bit": {
            "type": "boolean"
          },
          "isOnline": {
            "type": "boolean"
          },
          "lastSeen": {
            "type": "string",
            "format": "date-time"
          },
          "osArchitecture": {
            "$ref": "#/components/schemas/Architecture"
          },
          "platform": {
            "$ref": "#/components/schemas/SystemPlatform"
          },
          "processorCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int32"
          },
          "connectionId": {
            "type": "string"
          },
          "osDescription": {
            "type": "string"
          },
          "tenantId": {
            "type": "string",
            "format": "uuid"
          },
          "totalMemory": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "totalStorage": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "usedMemory": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "usedStorage": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "currentUsers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "macAddresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "publicIpV4": {
            "type": "string"
          },
          "publicIpV6": {
            "type": "string"
          },
          "localIpV4": {
            "type": "string"
          },
          "localIpV6": {
            "type": "string"
          },
          "drives": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Drive"
            }
          },
          "isOutdated": {
            "type": "boolean"
          },
          "dnsHostName": {
            "type": "string",
            "default": ""
          },
          "tagIds": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "alias": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "DeviceUpdateRequestDto": {
        "required": [
          "id",
          "tenantId",
          "name",
          "agentVersion",
          "is64Bit",
          "osArchitecture",
          "osDescription",
          "platform",
          "processorCount",
          "cpuUtilization",
          "totalMemory",
          "totalStorage",
          "usedMemory",
          "usedStorage",
          "currentUsers",
          "macAddresses",
          "localIpV4",
          "localIpV6",
          "drives"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "tenantId": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "agentVersion": {
            "type": "string"
          },
          "is64Bit": {
            "type": "boolean"
          },
          "osArchitecture": {
            "$ref": "#/components/schemas/Architecture"
          },
          "osDescription": {
            "type": "string"
          },
          "platform": {
            "$ref": "#/components/schemas/SystemPlatform"
          },
          "processorCount": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": "integer",
            "format": "int32"
          },
          "cpuUtilization": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "totalMemory": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "totalStorage": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "usedMemory": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "usedStorage": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "currentUsers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "macAddresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "localIpV4": {
            "type": "string"
          },
          "localIpV6": {
            "type": "string"
          },
          "drives": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Drive"
            }
          },
          "dnsHostName": {
            "type": "string",
            "default": ""
          }
        }
      },
      "Drive": {
        "type": "object",
        "properties": {
          "driveType": {
            "$ref": "#/components/schemas/DriveType"
          },
          "rootDirectory": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "driveFormat": {
            "type": "string"
          },
          "freeSpace": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "totalSize": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": "number",
            "format": "double"
          },
          "volumeLabel": {
            "type": "string"
          }
        }
      },
      "DriveType": {
        "enum": [
          "Unknown",
          "NoRootDirectory",
          "Removable",
          "Fixed",
          "Network",
          "CDRom",
          "Ram"
        ]
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "RuntimeId": {
        "enum": [
          "win-x86",
          "win-x64",
          "osx-arm64",
          "osx-x64",
          "linux-x64"
        ]
      },
      "SystemPlatform": {
        "type": "integer"
      }
    },
    "securitySchemes": {
      "Cookie": {
        "type": "apiKey",
        "description": "Interactive browser session cookie",
        "name": ".AspNetCore.Identity.Application",
        "in": "cookie"
      },
      "PersonalAccessToken": {
        "type": "apiKey",
        "description": "Personal access token",
        "name": "x-personal-token",
        "in": "header"
      },
      "ServiceAccountCredential": {
        "type": "apiKey",
        "description": "Service account API key",
        "name": "x-api-key",
        "in": "header"
      }
    }
  },
  "tags": [
    {
      "name": "AgentUpdate"
    },
    {
      "name": "Devices"
    }
  ]
}
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ControlR.Viewer.Avalonia.ControlrViewer">

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://ControlR.Libraries.Avalonia/Resources/Theme.axaml" />
        <ResourceInclude Source="/Resources/Icons.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>
    <StyleInclude Source="avares://ControlR.Libraries.Avalonia/Resources/Styles.axaml" />
  </UserControl.Styles>

  <!-- ViewerShell will be added programmatically -->
</UserControl>

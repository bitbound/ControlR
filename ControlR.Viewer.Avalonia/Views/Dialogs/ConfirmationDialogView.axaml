<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dialogs="using:ControlR.Viewer.Avalonia.ViewModels.Dialogs"
             xmlns:assets="using:ControlR.Viewer.Avalonia.Assets"
             x:Class="ControlR.Viewer.Avalonia.Views.Dialogs.ConfirmationDialogView"
             x:DataType="dialogs:IConfirmationDialogViewModel">

  <Grid RowDefinitions="*,Auto"
        RowSpacing="16"
        MinWidth="420">
    <TextBlock Grid.Row="0"
               Text="{Binding Message}"
               TextWrapping="Wrap"
               FontSize="16" />

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Command="{Binding CancelCommand}"
              Content="{Binding CancelText}" />
      <Button Command="{Binding ConfirmCommand}"
              Background="{DynamicResource PrimaryColor}"
              Foreground="{DynamicResource PrimaryContrastText}"
              Content="{Binding ConfirmText}" />
    </StackPanel>
  </Grid>
</UserControl>
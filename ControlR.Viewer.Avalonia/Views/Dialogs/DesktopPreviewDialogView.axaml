<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:assets="using:ControlR.Viewer.Avalonia.Assets"
             xmlns:dialogs="using:ControlR.Viewer.Avalonia.ViewModels.Dialogs"
             x:Class="ControlR.Viewer.Avalonia.Views.Dialogs.DesktopPreviewDialogView"
             x:DataType="dialogs:IDesktopPreviewDialogViewModel">

  <Grid RowDefinitions="*,Auto"
        RowSpacing="12"
        MinHeight="380"
        MinWidth="600">
    <Grid Grid.Row="0">
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="8"
                  IsVisible="{Binding IsLoading}">
        <ProgressBar Width="280"
                     IsIndeterminate="True" />
        <TextBlock Text="{x:Static assets:Resources.RemoteControl_LoadingPreview}" />
      </StackPanel>

      <TextBlock HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 TextWrapping="Wrap"
                 TextAlignment="Center"
                 Classes="Error"
                 Text="{Binding ErrorMessage}"
                 IsVisible="{Binding HasError}" />

      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <Image Source="{Binding PreviewImageSource}"
               IsVisible="{Binding HasImage}" />
      </ScrollViewer>
    </Grid>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Classes="accent"
              Command="{Binding RefreshCommand}"
              Content="{x:Static assets:Resources.Refresh}" />
      <Button Command="{Binding CloseCommand}"
              Content="{x:Static assets:Resources.Close}" />
    </StackPanel>
  </Grid>
</UserControl>

@attribute [Route(ClientRoutes.TenantSettings)]
@attribute [Authorize(Roles = RoleNames.TenantAdministrator)]

@inject ITenantSettingsProvider TenantSettingsProvider
@inject ISnackbar Snackbar

<PageTitle>
  Tenant Settings
</PageTitle>

<PrimaryTitle>
  Tenant Settings
</PrimaryTitle>

<div class="mt-10">
  <MudText Typo="Typo.h6" Color="Color.Primary" GutterBottom>
    Show Notification to User
  </MudText>
  <MudText Typo="Typo.body2" Class="mb-3">
    Controls whether users receive notifications when remote control sessions start.
  </MudText>
  
  <MudRadioGroup T="bool?" Value="_notifyUser" ValueChanged="SetNotifyUser">
    <MudRadio T="bool?" Value="@((bool?)null)" Color="Color.Primary">
      Use individual account setting
    </MudRadio>
    <MudRadio T="bool?" Value="@((bool?)true)" Color="Color.Primary">
      Always notify users
    </MudRadio>
    <MudRadio T="bool?" Value="@((bool?)false)" Color="Color.Primary">
      Never notify users
    </MudRadio>
  </MudRadioGroup>

  <div class="mt-10">
    <MudText Typo="Typo.h6" Color="Color.Primary" GutterBottom>
      Instance ID
    </MudText>
    <MudText Typo="Typo.body2" Class="mb-3">
      If enabled, the instance ID will be used for agent installations, allowing multiple agents from different servers to be installed on the same machine.
    </MudText>

    <MudCheckBox T="bool"
                 @bind-Value:get="_appendInstanceId"
                 @bind-Value:set="SetAppendInstanceId"
                 Label="Append instance ID to agent installations" />

    <MudTextField T="string"
                  @bind-Value="_instanceId"
                  Immediate="true"
                  Validation="@(new Func<string?, string?>(InstanceIdValidator))"
                  OnBlur="SaveInstanceIdOnBlur"
                  Label="Instance ID"
                  Placeholder="If empty, defaults to this server's hostname."
                  Class="mt-3" />
  </div>
</div>

@code {
  private bool _appendInstanceId = true;
  private string? _instanceId;
  private bool? _notifyUser;

  protected override async Task OnInitializedAsync()
  {
    var settings = await TenantSettingsProvider.GetSettings();
    _notifyUser = settings.NotifyUserOnSessionStart;
    _appendInstanceId = settings.AppendInstanceId ?? false;
    _instanceId = settings.InstanceId;
    await base.OnInitializedAsync();
  }

  private static string? InstanceIdValidator(string? value)
  {
    var trimmedValue = value?.Trim();

    if (string.IsNullOrWhiteSpace(trimmedValue))
    {
      return null;
    }

    return SharedValidators.ValidateInstanceId(trimmedValue);
  }

  private async Task SaveInstanceIdOnBlur(FocusEventArgs _)
  {
    await SaveInstanceId();
  }

  private async Task SaveInstanceId()
  {
    var validationMessage = InstanceIdValidator(_instanceId);
    if (validationMessage is not null)
    {
      Snackbar.Add(validationMessage, Severity.Error);
      return;
    }

    _instanceId = string.IsNullOrWhiteSpace(_instanceId)
      ? null
      : _instanceId.Trim();

    if (await TenantSettingsProvider.SetInstanceId(_instanceId))
    {
      Snackbar.Add("Setting updated", Severity.Success);
    }
  }

  private async Task SetAppendInstanceId(bool value)
  {
    _appendInstanceId = value;
    await TenantSettingsProvider.SetAppendInstanceId(value);
    Snackbar.Add("Setting updated", Severity.Success);
  }

  private async Task SetNotifyUser(bool? value)
  {
    _notifyUser = value;
    await TenantSettingsProvider.SetNotifyUserOnSessionStart(value);
    Snackbar.Add("Setting updated", Severity.Success);
  }
}
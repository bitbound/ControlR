@using System.Collections.Immutable
@using ControlR.Web.Client.StateManagement.Stores

@inject IUserTagStore UserTagStore

<MudSelect T="string" MultiSelection="true"
           QuickSearchInterval="@(TimeSpan.FromMilliseconds(50))"
           Text="@GetText()" MultiSelectionTextFunc="@GetTagsMultiSelectText"
           AdornmentIcon="@Icons.Material.Filled.Tag" Adornment="Adornment.End"
           SelectedValues="_selectedTags" SelectedValuesChanged="OnSelectedTagsChanged" SelectAll="true" FullWidth="false"
           SelectAllText="All Tags" Immediate="true" Class="ms-3">
  @foreach (var tag in UserTagStore.Items)
  {
    <MudSelectItem Value="@tag.Name">
      @tag.Name
    </MudSelectItem>
  }
</MudSelect>

  @code {
  private HashSet<string> _selectedTags = [];
  private ImmutableArray<TagViewModel> _selectedTagViewModels = [];

  [Parameter]
  public EventCallback<ImmutableArray<TagViewModel>> SelectedTagsChanged { get; set; }

  [Parameter]
  public bool NoneSelected { get; set; }

  [Parameter]
  public EventCallback<bool> NoneSelectedChanged { get; set; }


  protected override async Task OnInitializedAsync()
  {
    await base.OnInitializedAsync();

    if (UserTagStore.Items.Count == 0)
    {
      await UserTagStore.Refresh();
    }

    _selectedTags = [.. UserTagStore.Items.Select(x => x.Name)];
  }

  private string GetTagsMultiSelectText(List<string> tags)
  {
    if (tags.Count == 0)
    {
      return "No tags selected";
    }

    if (_selectedTags.Count == UserTagStore.Items.Count)
    {
      return "All tags selected";
    }

    var tagNoun = tags.Count > 1 ? "tags" : "tag";
    return $"{tags.Count} {tagNoun} selected";
  }

  private string GetText()
  {
    if (_selectedTags.Count == 0)
    {
      return "Showing items with no tags";
    }

    if (_selectedTags.Count == UserTagStore.Items.Count)
    {
      return "All tags selected";
    }

    var tagNoun = _selectedTags.Count > 1 ? "tags" : "tag";
    return $"{_selectedTags.Count} {tagNoun} selected";
  }

  private async Task OnSelectedTagsChanged(IEnumerable<string>? tags)
  {
    _selectedTags = tags?.ToHashSet() ?? [];

    if (_selectedTags.Count == 0)
    {
      _selectedTagViewModels = [];
      NoneSelected = true;
    }
    else
    {
      _selectedTagViewModels = UserTagStore.Items
        .Where(x => _selectedTags.Contains(x.Name))
        .ToImmutableArray();
      NoneSelected = false;
    }

    await NoneSelectedChanged.InvokeAsync(NoneSelected);
    await SelectedTagsChanged.InvokeAsync([.. _selectedTagViewModels]);
  }
}
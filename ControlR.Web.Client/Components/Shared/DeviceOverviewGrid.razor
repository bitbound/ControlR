<div class="device-overview-container">
<MudGrid>
  <MudItem xs="12" sm="12" md="6" lg="4" Class="text-center mb-6">
    <MudText Typo="Typo.h6" GutterBottom Color="Color.Primary">
      Device Summary
    </MudText>
    <div class="w-100">
      <div class="child-content-grid">

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Name:
        </MudText>
        <MudText Typo="Typo.body1">
          @Device.Name
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Alias:
        </MudText>
        <div class="d-flex align-center gap-2">
          @if (_isEditingAlias)
          {
            <MudTextField T="string" @bind-Value="_aliasValue" Immediate Variant="Variant.Text" MaxLength="100"
                          Disabled="@_isSavingAlias" Validation="@((string x) => ValidateAlias(x))" @onkeydown="HandleAliasKeyDown"
                          Class="flex-grow-1" />
            <MudTooltip Text="Cancel">
              <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" Size="Size.Small"
                             Disabled="@_isSavingAlias" OnClick="CancelEditAlias" />
            </MudTooltip>
            <MudTooltip Text="Save">
              <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small"
                             Disabled="@_isSavingAlias" OnClick="SaveAlias" />
            </MudTooltip>
          }
          else
          {
            <MudText Typo="Typo.body1" Class="flex-grow-1 align-self-center">
              @_aliasValue
            </MudText>
            <MudTooltip Text="Edit Alias">
              <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small"
                             OnClick="StartEditAlias" />
            </MudTooltip>
          }
        </div>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Online Status:
        </MudText>
        <MudText Typo="Typo.body1">
          @if (Device.IsOnline)
          {
            if (Device.IsOutdated)
            {
              <MudTooltip Text="Online (Outdated)">
                <MudIcon Icon="@(Icons.Material.Filled.Warning)" Color="@(Color.Warning)" />
              </MudTooltip>
            }
            else
            {
              <MudTooltip Text="Online">
                <MudIcon Icon="@(Icons.Material.Filled.Check)" Color="@(Color.Success)" />
              </MudTooltip>
            }
          }
          else
          {
            <MudTooltip Text="Offline">
              <MudIcon Icon="@(Icons.Material.Filled.Cancel)" Color="@(Color.Error)" />
            </MudTooltip>
          }
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Platform:
        </MudText>
        <div>
          @switch (Device.Platform)
          {
            case SystemPlatform.Windows:
              <MudTooltip Text="Windows">
                <MudIcon Icon="@(Icons.Custom.Brands.MicrosoftWindows)" Color="Color.Info" />
              </MudTooltip>
              ;
              break;
            case SystemPlatform.MacOs:
              <MudTooltip Text="macOS">
                <MudIcon Icon="@(Icons.Custom.Brands.Apple)" Color="Color.Info" />
              </MudTooltip>
              ;
              break;
            case SystemPlatform.Linux:
              <MudTooltip Text="Linux">
                <MudIcon Icon="@(Icons.Custom.Brands.Linux)" Color="Color.Info" />
              </MudTooltip>
              ;
              break;
            default:
              <MudTooltip Text="Unknown Platform">
                <MudIcon Icon="@Icons.Material.Filled.Help" Color="Color.Warning" />
              </MudTooltip>
              ;
              break;
          }
        </div>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Id:
        </MudText>
        <div class="d-flex align-center gap-2">
          <MudText Typo="Typo.body1">
            @Device.Id
          </MudText>
          <MudTooltip Text="Copy ID">
            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Color="Color.Default" Size="Size.Small"
                           OnClick="CopyDeviceId" />
          </MudTooltip>
        </div>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Agent Version:
        </MudText>
        <MudText Typo="Typo.body1">
          @Device.AgentVersion
        </MudText>

        @if (Device.CurrentUsers.Length > 0)
        {
          <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
            Active Users:
          </MudText>
          <MudText Typo="Typo.body1">
            @(GetCurrentUsersDisplay())
          </MudText>
        }

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Last Seen:
        </MudText>
        <MudText Typo="Typo.body1">
          @Device.LastSeen.ToLocalTime()
        </MudText>
      </div>
    </div>
  </MudItem>

  <MudItem xs="12" sm="12" md="6" lg="4" Class="text-center mb-6">
    <MudText Typo="Typo.h6" GutterBottom Color="Color.Primary">
      System Information
    </MudText>
    <div class="w-100">
      <div class="child-content-grid">
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          OS Description:
        </MudText>
        <MudTooltip Text="@Device.OsDescription">
          <MudText Typo="Typo.body1" Class="ellipsis-text">
            @Device.OsDescription
          </MudText>
        </MudTooltip>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Architecture:
        </MudText>
        <MudText Typo="Typo.body1">
          @(Device.OsArchitecture.ToString()) @(Device.Is64Bit ? "(64-bit)" : "(32-bit)")
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Processor Count:
        </MudText>
        <MudText Typo="Typo.body1">
          @(Device.ProcessorCount)
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Total Memory:
        </MudText>
        <MudText Typo="Typo.body1">
          @(Device.TotalMemory.ToString("N2")) GB
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Total Storage (OS):
        </MudText>
        <MudText Typo="Typo.body1">
          @(Device.TotalStorage.ToString("N0")) GB
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Used Storage (OS):
        </MudText>
        <MudText Typo="Typo.body1">
          @(GetUsedStorageDisplay())
        </MudText>
      </div>
    </div>
  </MudItem>

  <MudItem xs="12" sm="12" md="6" lg="4" Class="text-center">
    <MudText Typo="Typo.h6" GutterBottom Color="Color.Primary">
      Networking
    </MudText>
    <div class="w-100">
      <div class="child-content-grid">
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Public IPv4:
        </MudText>
        <MudText Typo="Typo.body1">
          @Device.PublicIpV4
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Public IPv6:
        </MudText>
        <MudText Typo="Typo.body1">
          @Device.PublicIpV6
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Local IPv4:
        </MudText>
        <MudText Typo="Typo.body1">
          @Device.LocalIpV4
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          Local IPv6:
        </MudText>
        <MudText Typo="Typo.body1">
          @Device.LocalIpV6
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          DNS Hostname:
        </MudText>
        <MudText Typo="Typo.body1">
          @Device.DnsHostName
        </MudText>

        <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
          MAC Addresses:
        </MudText>
        <MudText Typo="Typo.body1">
          @(string.Join(", ", Device.MacAddresses))
        </MudText>
      </div>
    </div>
  </MudItem>

  <MudFlexBreak />

  <MudItem xs="12" sm="12" md="6" lg="4" Class="text-center mb-6">
    <MudText Typo="Typo.h6" GutterBottom Color="Color.Primary">
      CPU Usage
    </MudText>
    <RadialGauge Value="@(Device.CpuUtilization)" MaxValue="1" Width="250px" Height="250px">
      <MudText Typo="Typo.body1">
        @(Math.Round(Device.CpuUtilization * 100, 2))%
      </MudText>
    </RadialGauge>
  </MudItem>

  <MudItem xs="12" sm="12" md="6" lg="4" Class="text-center mb-6">
    <MudText Typo="Typo.h6" GutterBottom Color="Color.Primary">
      Memory Usage
    </MudText>
    <RadialGauge Value="@(Device.UsedMemoryPercent)" MaxValue="1" Height="250px" Width="250px" Class="text-center">
      <MudText Typo="Typo.body1">
        @(Math.Round(Device.UsedMemoryPercent * 100, 2))%
      </MudText>
    </RadialGauge>
  </MudItem>

  @foreach (var drive in Device.Drives)
  {
    <MudItem xs="12" sm="12" md="6" lg="4" Class="text-center mb-6">
      <MudText Typo="Typo.h6" Color="Color.Primary" Class="ellipsis-text">
        Hard Drive
      </MudText>
      <MudChart ChartType="ChartType.Donut" Width="250px" Height="250px" Class="d-inline-block"
                ChartSeries="@GetDriveChartSeries(drive)"
                ChartLabels='@(new string[] { $"Used Space ({drive.UsedSpacePercentFormatted})", $"Free Space ({drive.FreeSpacePercentFormatted})" })'>
        <CustomGraphics>
          <text x="50%" y="40%" dominant-baseline="middle" text-anchor="middle" fill="@(Palette?.TextPrimary)"
                font-family="Helvetica" font-size="16">
            Total
          </text>
          <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" fill="@(Palette?.TextPrimary)"
                font-family="Helvetica" font-size="20">
            @(drive.TotalSize.ToString("N0")) GB
          </text>
        </CustomGraphics>
      </MudChart>
      <div class="w-100">
        <div class="child-content-grid">
          <MudText Typo="Typo.subtitle1" Color="Color.Tertiary">
            Name:
          </MudText>
          <MudTooltip Text="@drive.Name">
            <MudText Typo="Typo.body1" Class="ellipsis-text">
              @drive.Name
            </MudText>
          </MudTooltip>

          <MudText Typo="Typo.subtitle1" Color="Color.Tertiary">
            Volume Label:
          </MudText>
          <MudTooltip Text="@drive.VolumeLabel">
            <MudText Typo="Typo.body1" Class="ellipsis-text">
              @drive.VolumeLabel
            </MudText>
          </MudTooltip>

          <MudText Typo="Typo.subtitle1" Color="Color.Tertiary">
            Format:
          </MudText>
          <MudText Typo="Typo.body1">
            @drive.DriveFormat
          </MudText>

          <MudText Typo="Typo.subtitle1" Color="Color.Tertiary">
            Root Directory:
          </MudText>
          <MudTooltip Text="@drive.RootDirectory">
            <MudText Typo="Typo.body1" Class="ellipsis-text">
              @drive.RootDirectory
            </MudText>
          </MudTooltip>
        </div>
      </div>

    </MudItem>
  }
</MudGrid>
</div>

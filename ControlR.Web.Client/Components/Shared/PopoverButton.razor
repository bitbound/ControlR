@inherits JsInteropableComponent

<div id="@_elementId" class="popover-wrapper d-inline-flex align-center">
  <MudTooltip Text="@TooltipText" Class="z9002">

    @if (HideLabelOnMobile && CurrentBreakpoint < Breakpoint.Sm)
    {
      <MudIconButton Icon="@StartIcon"
                     Variant="@Variant"
                     Size="Size.Small"
                     OnClick="TogglePopover" />
    }
    else
    {
      <MudButton Variant="@Variant"
                 StartIcon="@StartIcon"
                 EndIcon="@EndIcon"
                 IconSize="Size.Large"
                 Size="Size.Small"
                 OnClick="TogglePopover">
        @Label
      </MudButton>
    }
  </MudTooltip>

  <MudPopover Open="@_isOpen"
              AnchorOrigin="Origin.BottomLeft"
              TransformOrigin="Origin.TopLeft"
              Class="pa-4"
              Style="max-height: 80vh; overflow-y: auto;">
    <div @onclick:stopPropagation="true">
      @ChildContent
    </div>
  </MudPopover>
</div>

<div>
  @if (!_loading && _anyDevicesForUser == false)
  {
    <MudAlert Severity="Severity.Info">
      No devices found. Head over to the <MudLink Color="Color.Tertiary" Href="/deploy">Deploy Page</MudLink>
      to install an agent!
    </MudAlert>
  }

  <div class="dashboard-header">
    <MudText Typo="Typo.h4" Color="Color.Primary" Class="dashboard-title">
      Devices
    </MudText>

    <div class="dashboard-header-actions">
      <div class="dashboard-search-container">
        <MudTextField T="string" Value="@_searchText" ValueChanged="OnSearch" Placeholder="Search devices" Clearable
                      Adornment="Adornment.Start" Immediate DebounceInterval="500" AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium" Class="dashboard-search" />
      </div>

      <MudTooltip Text="Refresh">
        <MudIconButton Variant="Variant.Outlined" Color="Color.Info" Icon="@(Icons.Material.Filled.Refresh)"
                       OnClick="HandleRefreshClicked" />
      </MudTooltip>
    </div>
  </div>

  <MudPaper Elevation="0" Class="pa-3 mb-3">
    <div class="dashboard-toolbar-main">
      <div class="dashboard-scope-controls">
        <div class="dashboard-tags-selector">
          <UserTagsSelector @bind-SelectedTags:get="_selectedTags" @bind-SelectedTags:set="@OnSelectedTagsChanged" />
        </div>

        <div class="dashboard-toolbar-options">
          <MudCheckBox T="bool" Value="_includeUntaggedDevices" ValueChanged="IncludeUntaggedDevicesChanged"
                       Label="Include untagged" Class="dashboard-checkbox" />

          <MudCheckBox T="bool" Value="_hideOfflineDevices" ValueChanged="HideOfflineDevicesChanged"
                       Label="Hide offline" Disabled="ShouldBypassHideOfflineDevices" Class="dashboard-checkbox" />

          <MudCheckBox T="bool" Value="_openDeviceInNewTab" ValueChanged="OpenDeviceInNewTabChanged"
                       Label="Open in new tab" Class="dashboard-checkbox" />
        </div>
      </div>
    </div>

    @if (!_loading && !HasScopeSelection)
    {
      <MudAlert Severity="Severity.Info" Dense="true" Class="dashboard-inline-alert mt-3">
        Select at least one tag or include untagged devices.
      </MudAlert>
    }

    @if (!_loading && HasHiddenUntaggedDevices)
    {
      <MudAlert Severity="Severity.Warning" Dense="true" Class="dashboard-inline-alert mt-3"
                Icon="@(Icons.Material.Filled.LabelOff)">
        @HiddenUntaggedAlertText
      </MudAlert>
    }
  </MudPaper>

  <MudDataGrid T="DeviceViewModel" @ref="_dataGrid" ServerData="LoadServerData" @bind-RowsPerPage="_rowsPerPage"
               SortMode="SortMode.Multiple" Loading="_loading" Hideable="true" SortDefinitions="_sortDefinitions"
               ShowColumnOptions="true" Filterable="true">

    <Columns>
      <TemplateColumn T="DeviceViewModel" Sortable="false" Filterable="false" ShowColumnOptions="false" Title="Actions">
        <CellTemplate>
          <div class="d-flex align-center">
            <MudTooltip Text="Actions">
              <MudMenu Variant="Variant.Outlined" Color="Color.Primary" Icon="@(Icons.Material.Filled.MoreVert)">

                <MudMenuItem Icon="@(Icons.Material.Filled.Computer)" IconColor="Color.Info"
                            OnClick="@(() => LaunchDeviceAccess(context.Item))">
                  Device Access
                </MudMenuItem>

                @if (context.Item.Dto.IsOnline)
                {
                  <MudMenuItem Icon="@(Icons.Material.Filled.Refresh)" IconColor="Color.Success"
                              OnClick="@(() => RefreshDeviceInfo(context.Item))">
                    Refresh
                  </MudMenuItem>

                  @if (context.Item.Dto.IsOutdated)
                  {
                    <MudMenuItem Icon="@(Icons.Material.Filled.Update)" IconColor="Color.Warning"
                                OnClick="@(() => UpdateDevice(context.Item.Id))">
                      Update
                    </MudMenuItem>
                  }

                  <MudMenuItem Icon="@(Icons.Material.Filled.PowerOff)" IconColor="Color.Error"
                              OnClick="@(() => ShutdownDevice(context.Item))">
                    Shutdown
                  </MudMenuItem>
                  <MudMenuItem Icon="@(Icons.Material.Filled.RestartAlt)" IconColor="Color.Error"
                              OnClick="@(() => RestartDevice(context.Item))">
                    Restart
                  </MudMenuItem>
                  <MudMenuItem Icon="@(Icons.Material.Filled.DeleteForever)" IconColor="Color.Error"
                              OnClick="@(() => UninstallAgent(context.Item))">
                    Uninstall
                  </MudMenuItem>
                }
                else
                {
                  <MudMenuItem Icon="@(Icons.Material.Filled.Visibility)" IconColor="Color.Success"
                              OnClick="@(() => WakeDevice(context.Item))">
                    Wake
                  </MudMenuItem>
                  <MudMenuItem Icon="@(Icons.Material.Filled.Delete)" IconColor="Color.Error"
                              OnClick="@(() => RemoveDevice(context.Item))">
                    Remove
                  </MudMenuItem>
                }
              </MudMenu>
            </MudTooltip>

            <MudTooltip Text="Remote Control">
              <MudIconButton Icon="@(Icons.Material.Filled.ScreenShare)" Color="Color.Info"
                            Disabled="!context.Item.Dto.IsOnline" OnClick="@(() => LaunchRemoteControl(context.Item))" Class="ml-2" />
            </MudTooltip>
          </div>
        </CellTemplate>
      </TemplateColumn>

      <PropertyColumn Title="Name" Property="x => x.Dto.Name" Sortable="true" Filterable="true" StickyLeft="true">
        <CellTemplate>
          @context.Item.Dto.Name
        </CellTemplate>
      </PropertyColumn>

      <PropertyColumn Title="Alias" Property="x => x.Dto.Alias" Sortable="true" Filterable="true">
        <CellTemplate>
          @context.Item.Dto.Alias
        </CellTemplate>
      </PropertyColumn>

      <PropertyColumn Property="@(x => x.Dto.IsOnline)" Sortable="true" Filterable="true" Title="Online">
        <CellTemplate>
          @if (context.Item.Dto.IsOnline)
          {
            if (context.Item.Dto.IsOutdated)
            {
              <MudTooltip Text="Online (Outdated)">
                <MudIcon Icon="@(Icons.Material.Filled.Warning)" Color="@(Color.Warning)" />
              </MudTooltip>
            }
            else
            {
              <MudTooltip Text="Online">
                <MudIcon Icon="@(Icons.Material.Filled.Check)" Color="@(Color.Success)" />
              </MudTooltip>
            }
          }
          else
          {
            <MudTooltip Text="Offline">
              <MudIcon Icon="@(Icons.Material.Filled.Cancel)" Color="@(Color.Error)" />
            </MudTooltip>
          }
        </CellTemplate>
      </PropertyColumn>

      <TemplateColumn T="DeviceViewModel" Sortable="false" Filterable="false" Title="Tags">
        <CellTemplate>
          @{
            var tagCount = context.Item.Dto.TagIds?.Length ?? 0;
          }

          @if (tagCount == 0)
          {
            <MudTooltip Text="Untagged device">
              <MudText Typo="Typo.body2" Color="Color.Warning">
                <strong>0</strong>
              </MudText>
            </MudTooltip>
          }
          else
          {
            <MudTooltip Text="@($"{tagCount} tag{(tagCount == 1 ? string.Empty : "s")}")">
              <MudText Typo="Typo.body2">@tagCount</MudText>
            </MudTooltip>
          }
        </CellTemplate>
      </TemplateColumn>

      <PropertyColumn Property="@(x => x.Dto.Platform)" Sortable="true" Filterable="true" Title="Platform">
        <CellTemplate>
          @switch (context.Item.Dto.Platform)
          {
            case SystemPlatform.Windows:
              <MudTooltip Text="Windows">
                <MudIcon Icon="@(Icons.Custom.Brands.MicrosoftWindows)" Color="Color.Info" />
              </MudTooltip>
                        ;
              break;
            case SystemPlatform.MacOs:
              <MudTooltip Text="macOS">
                <MudIcon Icon="@(Icons.Custom.Brands.Apple)" Color="Color.Info" />
              </MudTooltip>
                        ;
              break;
            case SystemPlatform.Linux:
              <MudTooltip Text="Linux">
                <MudIcon Icon="@(Icons.Custom.Brands.Linux)" Color="Color.Info" />
              </MudTooltip>
                        ;
              break;
            default:
              <MudTooltip Text="Unknown Platform">
                <MudIcon Icon="@Icons.Material.Filled.Help" Color="Color.Warning" />
              </MudTooltip>
                        ;
              break;
          }
        </CellTemplate>
      </PropertyColumn>

      <PropertyColumn Property="x => x.Dto.CurrentUsers" Title="Current Users" Sortable="false" Filterable="false">
        <CellTemplate>
          @(string.Join(", ", context.Item.Dto.CurrentUsers))
        </CellTemplate>
      </PropertyColumn>

      <PropertyColumn Property="@(x => x.Dto.CpuUtilization)" Title="CPU" Sortable="true" Filterable="true">
        <CellTemplate>
          @($"{Math.Round(context.Item.Dto.CpuUtilization * 100, 2)}%")
        </CellTemplate>
      </PropertyColumn>

      <PropertyColumn Property="@(x => x.Dto.UsedMemoryPercent)" Title="Memory" Sortable="true" Filterable="true">
        <CellTemplate>
          @($"{Math.Round(context.Item.Dto.UsedMemoryPercent * 100, 2)}%")
        </CellTemplate>
      </PropertyColumn>

      <PropertyColumn Property="@(x => x.Dto.UsedStoragePercent)" Title="Storage" Sortable="true" Filterable="true">
        <CellTemplate>
          @($"{Math.Round(context.Item.Dto.UsedStoragePercent * 100, 2)}%")
        </CellTemplate>
      </PropertyColumn>

      <HierarchyColumn T="DeviceViewModel" />
    </Columns>
    <ChildRowContent>
      <DeviceOverviewGrid Device="context.Item.Dto" />
    </ChildRowContent>

    <PagerContent>
      <MudDataGridPager T="DeviceViewModel" />
      <div class="dashboard-pager-stats pa-4">
        <MudText Typo="Typo.body2">Online: @_filterCounts.OnlineDevices</MudText>
        <MudText Typo="Typo.body2">|</MudText>
        <MudText Typo="Typo.body2">Offline: @_filterCounts.OfflineDevices</MudText>
        <MudText Typo="Typo.body2">|</MudText>
        <MudText Typo="Typo.body2">Total: @_totalFilteredDevices</MudText>
      </div>
    </PagerContent>
  </MudDataGrid>
</div>
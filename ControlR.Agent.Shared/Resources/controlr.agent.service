[Unit]
Description=ControlR is an open-source remote control and remote access solution.

[Service]
WorkingDirectory={{INSTALL_DIRECTORY}}
ExecStart={{INSTALL_DIRECTORY}}/ControlR.Agent run{{INSTANCE_ARGS}}
Restart=always
KillMode=process
StartLimitIntervalSec=0
Environment=DOTNET_ENVIRONMENT=Production
Environment=DOTNET_BUNDLE_EXTRACT_BASE_DIR={{INSTALL_DIRECTORY}}
RestartSec=10

[Install]
WantedBy=multi-user.target
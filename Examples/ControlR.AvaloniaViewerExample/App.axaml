<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ControlR.AvaloniaViewerExample.App"
             xmlns:local="using:ControlR.AvaloniaViewerExample"
             RequestedThemeVariant="Dark">

  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://ControlR.Libraries.Avalonia/Resources/Theme.axaml" />
        <ResourceInclude Source="avares://ControlR.Viewer.Avalonia/Resources/Icons.axaml" />

      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <DevolutionsDevExpressTheme />
    <StyleInclude Source="avares://ControlR.Libraries.Avalonia/Resources/Styles.axaml" />
    <!-- <FluentTheme>
      <FluentTheme.Palettes>
        <ColorPaletteResources x:Key="Dark"
                               Accent="#2196F3"
                               RegionColor="#121212"/>
        <ColorPaletteResources x:Key="Light"
                               Accent="#2196F3"
                               RegionColor="#FAFAFA"/>
      </FluentTheme.Palettes>
    </FluentTheme> -->
  </Application.Styles>
</Application>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ControlR.AvaloniaViewerExample.ViewModels"
        xmlns:fakes="using:ControlR.AvaloniaViewerExample.ViewModels.Fakes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ctrlr="using:ControlR.Viewer.Avalonia"
        xmlns:cavac="using:ControlR.Libraries.Avalonia.Controls"
  xmlns:nav="using:ControlR.Viewer.Avalonia.Services.Navigation"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="ControlR.AvaloniaViewerExample.Views.MainWindow"
        x:DataType="vm:IMainWindowViewModel"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/appicon.ico"
        Title="ControlR Viewer Example">

  <Window.Styles>
    <Style Selector="ListBox#SidebarNavList">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ListBox#SidebarNavList /template/ Border#border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBoxItem.SidebarNavItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="ListBoxItem.SidebarNavItem /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="14,12" />
    </Style>

    <Style Selector="ListBoxItem.SidebarNavItem PathIcon">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style Selector="ListBoxItem.SidebarNavItem TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource DefaultColor}" />
    </Style>

    <Style Selector="ListBoxItem.SidebarNavItem:selected PathIcon">
      <Setter Property="Foreground" Value="{DynamicResource InfoColor}" />
    </Style>

    <Style Selector="ListBoxItem.SidebarNavItem:selected TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource InfoColor}" />
    </Style>

    <Style Selector="ListBoxItem.SidebarNavItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource DividerLightBrush}" />
    </Style>

    <Style Selector="ListBox#SidebarNavList:disabled">
      <Setter Property="Opacity" Value="0.55" />
    </Style>

    <Style Selector="ListBox#SidebarNavList:disabled ListBoxItem.SidebarNavItem">
      <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <Style Selector="ListBox#SidebarNavList:disabled ListBoxItem.SidebarNavItem TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style Selector="ListBox#SidebarNavList:disabled ListBoxItem.SidebarNavItem PathIcon">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
  </Window.Styles>

  <Design.DataContext>
    <fakes:MainWindowViewModelFake/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0"
            Padding="16,12"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="10">
        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   FontSize="18"
                   FontWeight="Bold"
                   Text="ControlR Viewer Example" />

        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   Text="Light" />

        <ToggleSwitch Grid.Column="2"
                      VerticalAlignment="Center"
                      OffContent="Light"
                      OnContent="Dark"
                      IsChecked="{Binding IsDarkMode}" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="220,*">
      <Border Grid.Column="0"
              Background="{DynamicResource BackgroundGrayBrush}"
              BorderBrush="{DynamicResource DividerBrush}"
              BorderThickness="0,0,1,0">
        <ListBox x:Name="SidebarNavList"
                 Margin="0,12,0,0"
                 Background="Transparent"
                 IsEnabled="{Binding IsVisible, ElementName=Viewer}"
                 SelectionChanged="SidebarNavList_OnSelectionChanged">
          <ListBoxItem Classes="SidebarNavItem"
                       Cursor="Hand"
                       Tag="{x:Static nav:ViewerPage.RemoteControl}">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <PathIcon Data="{DynamicResource share_desktop_regular}"
                        Width="20"
                        Height="20" />
              <TextBlock VerticalAlignment="Center"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Text="Remote Control" />
            </StackPanel>
          </ListBoxItem>

          <ListBoxItem Classes="SidebarNavItem"
                       Cursor="Hand"
                       Tag="{x:Static nav:ViewerPage.Terminal}">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <PathIcon Data="{DynamicResource code_regular}"
                        Width="20"
                        Height="20" />
              <TextBlock VerticalAlignment="Center"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Text="Terminal" />
            </StackPanel>
          </ListBoxItem>

          <ListBoxItem Classes="SidebarNavItem"
                       Cursor="Hand"
                       Tag="{x:Static nav:ViewerPage.FileSystem}">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <PathIcon Data="{DynamicResource desktop_regular}"
                        Width="20"
                        Height="20" />
              <TextBlock VerticalAlignment="Center"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Text="File System" />
            </StackPanel>
          </ListBoxItem>
        </ListBox>
      </Border>

      <Grid Grid.Column="1">
        <Border IsVisible="{Binding IsLoginVisible}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MaxWidth="480"
                Padding="28"
                Background="{DynamicResource BackgroundGrayBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="1"
                CornerRadius="18">
          <StackPanel Spacing="14">
            <TextBlock FontSize="24"
                       FontWeight="Bold"
                       Text="Sign in to the viewer" />

            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="Enter the ControlR server, device ID, and the same email and password you use in the web app. The OTP field only appears when the account requires two-factor authentication." />

            <TextBlock Text="Server URL" />
            <TextBox Text="{Binding ServerUrl}" />

            <TextBlock Text="Device ID" />
            <TextBox Text="{Binding DeviceIdText}" />

            <TextBlock Text="Email" />
            <TextBox Text="{Binding Email}" />

            <TextBlock Text="Password" />
            <TextBox Text="{Binding Password}"
                     PasswordChar="*" />

            <StackPanel IsVisible="{Binding RequiresTwoFactor}"
                        Spacing="6">
              <TextBlock Text="Authenticator code" />
              <TextBox Text="{Binding TwoFactorCode}" />
            </StackPanel>

            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource InfoColor}"
                       Text="{Binding StatusMessage}" />

            <StackPanel Orientation="Horizontal"
                        Spacing="10">
              <Button Content="Sign In"
                      MinWidth="140"
                      Command="{Binding SignInCommand}" />
              <Button Content="Reset"
                      MinWidth="100"
                      Command="{Binding SignOutCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <ctrlr:ControlrViewer x:Name="Viewer"
                              Options="{Binding ViewerOptions}"
                              Page="{Binding ActivePage}"
                              IsVisible="{Binding IsViewerVisible}" />
      </Grid>
    </Grid>
  </Grid>
</Window>

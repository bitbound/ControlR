{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build solution",
      "type": "shell",
      "command": "dotnet build ControlR.slnx --verbosity quiet",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "clear": true
      },
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "build agent",
      "type": "dotnet",
      "task": "build",
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": ["build server"],
      "problemMatcher": [],
      "file": "ControlR.Agent/ControlR.Agent.csproj"
    },
    {
      "label": "build desktopclient",
      "type": "dotnet",
      "task": "build",
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": ["build agent"],
      "problemMatcher": [],
      "file": "ControlR.DesktopClient/ControlR.DesktopClient.csproj"
    },
    {
      "label": "build desktopclient mac",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "ControlR.DesktopClient/ControlR.DesktopClient.csproj",
        "-f",
        "net10.0-macos",
        "-r",
        "osx-arm64",
        "-p:_CanOutputAppBundle=false",
        "-p:GenerateDependencyFile=true",
        "-p:GenerateRuntimeConfigurationFiles=true",
        "--verbosity",
        "quiet"
      ],
      "group": "build",
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "build server",
      "type": "dotnet",
      "task": "build",
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": [],
      "problemMatcher": [],
      "file": "ControlR.Web.Server/ControlR.Web.Server.csproj"
    },
    {
      "label": "build loadtester",
      "type": "dotnet",
      "task": "build",
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": ["build server"],
      "problemMatcher": [],
      "file": "Tests/ControlR.Agent.LoadTester/ControlR.Agent.LoadTester.csproj"
    },
    {
      "label": "build web ui tests",
      "type": "dotnet",
      "task": "build",
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": ["build server"],
      "problemMatcher": [],
      "file": "Tests/ControlR.Web.Server.UITests/ControlR.Web.Server.UITests.csproj"
    },
    {
      "label": "build + compose",
      "dependsOn": ["build solution", "compose"],
      "dependsOrder": "sequence"
    },
    {
      "label": "wait for webapp",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/Wait-ControlRWebApp.ps1",
        "-Url",
        "https://localhost:7033",
        "-TimeoutSeconds",
        "90"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "install playwright browsers",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/Tests/ControlR.Web.Server.UITests/bin/Debug/net10.0/playwright.ps1",
        "install",
        "chromium"
      ],
      "dependsOrder": "sequence",
      "dependsOn": ["build web ui tests"],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "verify web ui smoke",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "Tests/ControlR.Web.Server.UITests/ControlR.Web.Server.UITests.csproj"
      ],
      "dependsOrder": "sequence",
      "dependsOn": ["build web ui tests", "install playwright browsers"],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "kill agent",
      "type": "shell",
      "command": "pkill -f \"ControlR\\.Agent\\b\" || true; pkill -f \"dotnet watch.*ControlR\\.Agent\\.csproj\" || true; pkill -f \"dotnet run.*ControlR\\.Agent\\.csproj\" || true",
      "problemMatcher": [],
      "hide": true,
      "presentation": {
        "close": true
      }
    },
    {
      "label": "kill desktopclient",
      "type": "shell",
      "command": "pkill -f \"ControlR\\.DesktopClient\\b\" || true; pkill -f \"dotnet watch.*ControlR\\.DesktopClient\\.csproj\" || true; pkill -f \"dotnet run.*ControlR\\.DesktopClient\\.csproj\" || true",
      "problemMatcher": [],
      "hide": true,
      "presentation": {
        "close": true
      }
    },
    {
      "label": "kill server",
      "type": "shell",
      "command": "pkill -f \"ControlR\\.Web\\.Server\\b\" || true; pkill -f \"dotnet watch.*ControlR\\.Web\\.Server\\.csproj\" || true; pkill -f \"dotnet run.*ControlR\\.Web\\.Server\\.csproj\" || true",
      "problemMatcher": [],
      "hide": true,
      "presentation": {
        "close": true
      }
    },
    {
      "label": "compose",
      "type": "docker-compose",
      "dockerCompose": {
        "projectName": "controlr",
        "up": {
          "detached": true,
          "build": true,
          "services": ["postgres", "aspire"]
        },
        "files": [
          "${workspaceFolder}/docker-compose/docker-compose.yml",
          "${workspaceFolder}/docker-compose/docker-compose.override.yml"
        ]
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
